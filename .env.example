# --- Server ---
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# --- Retell -> Middleware auth ---
# Shared secret Retell must send in header `x-retell-secret` on every request.
RETELL_SHARED_SECRET=

# --- Guesty Booking Engine API (v1) ---
GUESTY_BE_CLIENT_ID=
GUESTY_BE_CLIENT_SECRET=
GUESTY_BE_BASE_URL=https://booking.guesty.com/api
GUESTY_BE_TOKEN_URL=https://booking.guesty.com/oauth2/token

# --- Guesty Open API (v2) ---
GUESTY_OAPI_CLIENT_ID=
GUESTY_OAPI_CLIENT_SECRET=
GUESTY_OAPI_BASE_URL=https://open-api.guesty.com/v1
GUESTY_OAPI_TOKEN_URL=https://open-api.guesty.com/oauth2/token

# --- Hotel booking site (for deep-link template) ---
# Confirm exact query-parameter names against a real URL copied from the live site.
BOOKING_SITE=https://thethomastyler.guestybookings.com

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX

# --- Listing map (JSON string) ---
# Maps suite display names to Guesty listing IDs. Suite names MUST match what the
# Retell agent will send. Keep keys exactly as the agent will say them.
LISTING_MAP={"Premium Square View Suite":"<<id>>","Premium Suite":"<<id>>","Premium Suite Main Level":"<<id>>","Garden Suite":"<<id>>","Garden Suite ADA":"<<id>>"}

# --- Feature flags ---
ENABLE_V2_LOOKUP=false
ENABLE_V2_POST_CALL=false
# Send the booking-link SMS through Guesty (Unified Inbox / Guesty number,
# threaded in the dashboard) instead of Twilio. Requires the Guesty SMS add-on
# and a provisioned number to be active on the account, plus GUESTY_OAPI_* creds.
ENABLE_GUESTY_SMS=false

# --- Optional: post-call logging sink (v2) ---
# Either a Google Sheets webhook URL, a CRM webhook, or leave blank to log only.
POST_CALL_WEBHOOK_URL=
# Optional Slack/WhatsApp alert webhook for new-booking follow-up
STAFF_ALERT_WEBHOOK_URL=

# --- Staff escalation (required in production) ---
# Who a callback actually reaches. Without STAFF_PRIMARY_NUMBER, /take_message
# accepts callback requests, delivers them to nobody, and the agent has already
# told the guest someone is ringing them back. The service refuses to start in
# production without it.
STAFF_PRIMARY_NUMBER=+1XXXXXXXXXX     # Andrew
STAFF_BACKUP_NUMBER=+1XXXXXXXXXX      # whoever answers at 2am

# --- n8n: owns delivery of receipts and pre-arrival email re-sends, because
# Guesty exposes no public endpoint for either ---
RECEIPT_WEBHOOK_URL=

# --- Guards /retell/inbound. Retell does not send x-retell-secret on the
# inbound webhook, so this route authenticates on a URL token instead.
# 32+ random chars. ---
INBOUND_WEBHOOK_TOKEN=dac8cd735bacf8facd824367a6495b1125fe7d3fa9b65120

# --- Retell's post-call webhook signing secret, from the Retell dashboard ---
RETELL_WEBHOOK_SECRET=
